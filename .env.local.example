# Copy this file to `.env.local` for local-only overrides.
# Do not enable these flags in preview or production.

# Local Playwright / smoke-only auth bypass.
# Required cookie: `reca-e2e-auth=1`
E2E_AUTH_BYPASS=0

# Optional override for the manual QA autofill date.
MANUAL_TEST_FILL_DATE=

# Optional locally. Required for real distributed rate limiting in preview/production.
# Used by `prewarm` and `interpretes`. `authLookupRateLimit` also uses Upstash,
# but in production it returns `503` if config/request fails instead of falling back.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# PostHog product analytics (server-routed, optional).
POSTHOG_PROJECT_TOKEN=
POSTHOG_HOST=https://us.i.posthog.com
