{
  "version": "0.2",
  "import": [
    "@cspell/dict-es-es/cspell-ext.json"
  ],
  "language": "en,es",
  "allowCompoundWords": true,
  "ignorePaths": [
    ".git",
    ".next",
    ".vercel",
    "**/*.test.ts",
    "**/*.test.tsx",
    "local-secrets/**",
    "memory/archive/**",
    "node_modules/**",
    "package-lock.json",
    "public/**",
    "supabase/**",
    "tsconfig.tsbuildinfo"
  ],
  "ignoreRegExpList": [
    "/https?:\\/\\/[^\\s)]+/g",
    "/[A-Za-z]:\\\\[^\\s]+/g",
    "/`[^`]+`/g",
    "/\\/[A-Za-z0-9_\\-./\\[\\]]+/g",
    "/\\b[a-z]+(?:_[a-z0-9]+)+\\b/g",
    "/\\b[a-z]+(?:[A-Z][a-z0-9]+)+\\b/g",
    "/\\b[A-Z][a-z0-9]+(?:[A-Z][a-z0-9]+)+\\b/g",
    "/sb_publishable_[A-Za-z0-9_]+/g",
    "/[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}/g"
  ],
  "words": [
    "actaTabs",
    "acompañamiento",
